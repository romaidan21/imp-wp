{
  "name": "bamboo",
  "private": true,
  "version": "1.0.0",
  "main": "bbg.mjs",
  "author": "Bambuk studio",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "clean": "node bbg.mjs clean",
    "start": "yarn && node bbg.mjs start",
    "dev": "node bbg.mjs start",
    "watch": "node bbg.mjs watch",
    "css": "node bbg.mjs css",
    "js": "node bbg.mjs js",
    "img": "node bbg.mjs img",
    "svg": "node bbg.mjs svg",
    "json": "node bbg.mjs json",
    "tpl": "node bbg.mjs tpl",
    "fonts": "node bbg.mjs fonts",
    "webp": "node bbg.mjs webp",
    "perf": "node bbg.mjs lighthouse",
    "perf:desktop": "node bbg.mjs lighthouse --device=desktop",
    "perf:mobile": "node bbg.mjs lighthouse --device=mobile",
    "build": "node bbg.mjs build",
    "build:css": "node bbg.mjs build:css",
    "build:js": "node bbg.mjs build:js",
    "build:img": "node bbg.mjs build:img",
    "build:json": "node bbg.mjs build:json",
    "build:tpl": "node bbg.mjs build:tpl",
    "build:fonts": "node bbg.mjs build:fonts",
    "build:webp": "node bbg.mjs build:webp",
    "build:svg": "node bbg.mjs build:svg",
    "backup": "node bbg.mjs backup",
    "deploy": "node bbg.mjs deploy",
    "db:create": "node bbg.mjs db:create",
    "db:backup": "node bbg.mjs db:backup",
    "db:migrate": "node bbg.mjs db:migrate",
    "db:export": "node bbg.mjs db:export",
    "db:delete": "node bbg.mjs db:delete",
    "db:rollback": "node bbg.mjs db:rollback",
    "app-to-staging": "node bbg.mjs deploy --to staging",
    "app-to-production": "node bbg.mjs deploy --to production",
    "theme-to-staging": "node bbg.mjs deploy --to staging --src wp-content/themes/bamboo",
    "theme-to-staging:build": "node bbg.mjs build && node bbg.mjs deploy --to staging --src wp-content/themes/bamboo",
    "theme-to-production": "node bbg.mjs build && node bbg.mjs deploy --to production --src wp-content/themes/bamboo",
    "theme-to-production:build": "node bbg.mjs deploy --to production --src wp-content/themes/bamboo",
    "backup-theme-staging": "node bbg.mjs backup --from staging --src wp-content/themes/bamboo",
    "backup-theme-production": "node bbg.mjs backup --from production --src wp-content/themes/bamboo",
    "backup-db-staging": "node bbg.mjs db:backup --from staging",
    "backup-db-production": "node bbg.mjs db:backup --from production",
    "db:to-staging": "node bbg.mjs db:migrate --to staging",
    "db:to-production": "node bbg.mjs db:migrate --to production",
    "db:from-staging": "node bbg.mjs db:migrate --from staging --to local",
    "db:from-production": "node bbg.mjs db:migrate --from production --to local",
    "app:from-staging": "node bbg.mjs sync --from staging --to local",
    "uploads:from-staging": "node bbg.mjs sync --from staging --to local --src wp-content/uploads"
  },
  "dependencies": {
    "gsap": "^3.14.2"
  },
  "devDependencies": {
    "@rspack/cli": "^1.6.7",
    "@rspack/core": "^1.6.7",
    "basic-ftp": "^5.0.5",
    "browserslist": "^4.28.1",
    "cli-color": "^2.0.4",
    "del": "^8.0.1",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.3.2",
    "lighthouse": "^12.2.1",
    "lightningcss": "^1.30.2",
    "node-notifier": "^10.0.1",
    "ora": "^8.1.1",
    "p-queue": "^8.1.0",
    "prompts": "^2.4.2",
    "sass": "^1.96.0",
    "sharp": "^0.34.5",
    "ssh2": "^1.17.0",
    "svgo": "^4.0.0",
    "ttf2woff2": "^8.0.0"
  },
  "resolutions": {
    "cpu-features": "npm:@favware/skip-dependency@latest"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead"
  ]
}
